# Neo — Personal Intelligence Agent
# Copy this file to .env.development and fill in your values.
# NEVER commit .env.development — it's gitignored.

# ============================================
# ENVIRONMENT
# ============================================
NEO_ENV=development  # development | production

# ============================================
# API KEYS
# ============================================
CLAUDE_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-google-ai-api-key-here

# ============================================
# USER PATHS
# ============================================
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
DEFAULT_SAVE_DIR=~/Documents/Neo
DOWNLOADS_DIR=~/Downloads

# ============================================
# OLLAMA (local model)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================
# DATABASE
# ============================================
NEO_DB_PATH=./data/neo.db

# ============================================
# GOOGLE APIs (Phase 3)
# ============================================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# VOICE (Phase 4)
# ============================================
# WHISPER_MODEL=base
# WAKE_WORD_ENABLED=false
